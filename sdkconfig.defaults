# FreeRTOS: estatisticas de CPU (vTaskGetRunTimeStats) — ver task_debug.cpp
CONFIG_FREERTOS_USE_TRACE_FACILITY=y
CONFIG_FREERTOS_GENERATE_RUN_TIME_STATS=y
CONFIG_FREERTOS_RUN_TIME_STATS_USING_ESP_TIMER=y

# lwIP: mais sockets TCP simultaneos (AsyncWebServer + clientes + FTP) — reduz falhas intermitentes de ligacao.
CONFIG_LWIP_MAX_SOCKETS=16

# --- Desempenho / equipamento sempre alimentado (sem foco em bateria) ---
# Power management do IDF: DFS e light sleep coordenados pelo PM ficam desativados.
# (Ja e' o default na lib high_perf; explicito para sobreviver a mudancas de default.)
# Nota: Wi-Fi usa binarios pre-compilados; politica "sem PS" no radio e' aplicada em net_services.cpp
# (esp_wifi_set_ps, esp_wifi_force_wakeup_acquire) — ver comentarios nesse ficheiro.
CONFIG_PM_ENABLE=n
