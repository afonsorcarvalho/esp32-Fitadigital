/**
 * @file integrity_secret.h.example
 * @brief MODELO da password de integridade. COPIAR para integrity_secret.h e EDITAR.
 *
 * integrity_secret.h NAO e' versionado (.gitignore). Cada build embute esta password
 * no firmware; a mesma string tem de estar na ferramenta de verificacao no PC
 * (tools/verify_integrity.py, via variavel de ambiente FDIGI_INT_SECRET).
 *
 * AVISO: e' um segredo partilhado igual em todos os devices. Quem tiver o firmware.bin
 * pode extrai-lo (reverse). Protege adulteracao casual do .txt, nao um atacante com
 * engenharia reversa. Trocar antes de producao e NUNCA commitar o valor real.
 */
#pragma once

#define FDIGI_INT_SECRET "TROCAR-ESTA-PASSWORD-antes-de-producao"
