# -----------------------------------------------------------------------------
# FitaDigital — ESP32-S3-Touch-LCD-4.3B (PlatformIO + Arduino-ESP32)
# Artefactos de build, dependências geridas e ficheiros locais da IDE.
# -----------------------------------------------------------------------------

# PlatformIO: build, libs descarregadas, ambientes
.pio
.pioenvs
.piolibdeps

# Metadados / caches de ferramentas (ex.: análise estática, Cursor)
.cache

# Ficheiros de compilação auxiliares (gerados localmente)
compile_commands.json
.clang_complete

# VS Code / C/C++ extension (gerados ou específicos da máquina)
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

# Cursor (preferências locais do projeto)
.cursor/

# CMake (se usar geradores externos)
cmake-build-*/
build/
CMakeCache.txt
CMakeFiles/

# Sistema operativo
.DS_Store
Thumbs.db
*.stackdump

# Registos e saídas locais de teste
*.log

# Firmware binaries arquivados por versao (tools/save_firmware_version.py).
# Nao versionar: reproduziveis a partir do source + FITADIGITAL_VERSION.
firmware_versions/

# Relatórios / exports de texto colocados por engano na raiz do firmware (ex.: autoclave)
119_*.txt

# Python (scripts auxiliares, se existirem)
__pycache__/
*.py[cod]
.venv/
venv/

# Secrets locais (credenciais por máquina). Descomente se criar overrides:
# platformio_local.ini
# secrets.ini
tools/test_out/

# Claude Code (project agents, skills, settings locais)
.claude/

# Git worktrees
.worktrees/
